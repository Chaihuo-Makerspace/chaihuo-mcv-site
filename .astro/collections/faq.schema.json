{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    }
  },
  "additionalProperties": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "label": {
        "type": "string"
      },
      "label_en": {
        "type": "string"
      },
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "question": {
              "type": "string"
            },
            "question_en": {
              "type": "string"
            },
            "answer": {
              "type": "string"
            },
            "answer_en": {
              "type": "string"
            }
          },
          "required": [
            "question",
            "answer"
          ]
        }
      }
    },
    "required": [
      "id",
      "label",
      "items"
    ]
  }
}