{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    }
  },
  "additionalProperties": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "image": {
        "type": "string",
        "format": "uri"
      },
      "alt": {
        "type": "string"
      }
    },
    "required": [
      "id",
      "image"
    ]
  }
}