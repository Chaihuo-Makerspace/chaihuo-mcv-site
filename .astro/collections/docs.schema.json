{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "人物访谈",
        "纪录片",
        "Vlog",
        "文章"
      ]
    },
    "description": {
      "type": "string"
    },
    "readTime": {
      "type": "string"
    },
    "coverImage": {
      "type": "string",
      "format": "uri"
    },
    "videoLinks": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "platform": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "required": [
          "platform",
          "url"
        ]
      }
    },
    "pdfName": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "category",
    "description"
  ]
}