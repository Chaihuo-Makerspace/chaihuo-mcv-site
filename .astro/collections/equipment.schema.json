{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    }
  },
  "additionalProperties": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "icon": {
        "type": "string"
      },
      "title": {
        "type": "string"
      },
      "title_en": {
        "type": "string"
      },
      "items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "name_en": {
              "type": "string"
            },
            "spec": {
              "type": "string"
            },
            "spec_en": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "spec"
          ]
        }
      }
    },
    "required": [
      "id",
      "icon",
      "title",
      "items"
    ]
  }
}