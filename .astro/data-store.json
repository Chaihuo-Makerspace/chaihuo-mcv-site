[["Map",1,2,132,133,189,190,228,229,251,252,259,260,321,322,348,349],"docs",["Map",3,4,28,29,46,47,69,70,87,88,111,112],"2026-02-28-village-workshop",{"id":3,"data":5,"filePath":16,"digest":17,"rendered":18},{"title":6,"date":7,"category":8,"description":9,"readTime":10,"coverImage":11,"videoLinks":12},"乡村创客工坊：连接数字与现实","2026.02.28","人物访谈","在云南某个小镇，基地车首次以移动创客空间的形式开放。当地的年轻人在车内体验3D打印、激光切割等数字制造技术，科技的种子在这片土地上悄然生根。","11 min","https://images.unsplash.com/photo-1611907045915-8357087b1878?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=600&q=80",[13],{"platform":14,"url":15},"YouTube","#","src/content/docs/2026-02-28-village-workshop.md","47d3df0ea7511dbb",{"html":19,"metadata":20},"",{"headings":21,"localImagePaths":22,"remoteImagePaths":23,"frontmatter":24,"imagePaths":27},[],[],[],{"title":6,"date":7,"category":8,"description":9,"readTime":10,"coverImage":11,"videoLinks":25},[26],{"platform":14,"url":15},[],"2026-03-15-offline-ai",{"id":28,"data":30,"filePath":37,"digest":38,"rendered":39},{"title":31,"date":32,"category":8,"description":33,"readTime":34,"coverImage":35,"videoLinks":36},"离线AI系统的实地验证","2026.03.15","在没有网络信号的偏远地区，我们的离线AI系统完成了首次实地应用测试。本地部署的大语言模型成功为当地社区提供技术咨询服务，证明了科技向善的可行性。","8 min","https://images.unsplash.com/photo-1562568068-7a90cf9e499d?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=600&q=80",[],"src/content/docs/2026-03-15-offline-ai.md","6e61f5a5f66f91c1",{"html":19,"metadata":40},{"headings":41,"localImagePaths":42,"remoteImagePaths":43,"frontmatter":44,"imagePaths":45},[],[],[],{"title":31,"date":32,"category":8,"description":33,"readTime":34,"coverImage":35},[],"2026-03-28-sichuan-tibet",{"id":46,"data":48,"filePath":58,"digest":59,"rendered":60},{"title":49,"date":50,"category":51,"description":52,"readTime":53,"coverImage":54,"videoLinks":55},"穿越川藏：1850公里的技术挑战","2026.03.28","Vlog","从成都出发，沿着318国道一路向西。基地车在海拔变化超过4000米的复杂路况中，经受了前所未有的考验。太阳能系统、AI计算平台、数字加工设备全部运行正常。","12 min","https://images.unsplash.com/photo-1755954774924-fe9a89858f7a?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=600&q=80",[56],{"platform":57,"url":15},"Bilibili","src/content/docs/2026-03-28-sichuan-tibet.md","fd349b1c8ee986d4",{"html":19,"metadata":61},{"headings":62,"localImagePaths":63,"remoteImagePaths":64,"frontmatter":65,"imagePaths":68},[],[],[],{"title":49,"date":50,"category":51,"description":52,"readTime":53,"coverImage":54,"videoLinks":66},[67],{"platform":57,"url":15},[],"2026-04-05-departure",{"id":69,"data":71,"filePath":78,"digest":79,"rendered":80},{"title":72,"date":73,"category":74,"description":75,"videoLinks":76,"pdfName":77},"基地车出发仪式","2026.04.05","文章","普罗米修斯号正式从深圳出发，开启 200 天的中国科技巡回之旅。出发仪式上，柴火创客社区的伙伴们为基地车送行。",[],"Annual_Report_2025.pdf","src/content/docs/2026-04-05-departure.md","f725e939468d28cf",{"html":19,"metadata":81},{"headings":82,"localImagePaths":83,"remoteImagePaths":84,"frontmatter":85,"imagePaths":86},[],[],[],{"title":72,"date":73,"category":74,"description":75,"pdfName":77},[],"2026-04-17-relay-tower",{"id":87,"data":89,"filePath":99,"digest":100,"rendered":101},{"title":90,"date":91,"category":92,"description":93,"readTime":94,"coverImage":95,"videoLinks":96},"科技服务于荒野：基站中继塔搭建完成","2026.04.17","纪录片","在深夜的戈壁滩上我们与团队完成 3G + 边缘计算增幅建设，创建空心区域共享工作技术生态环境。","15 min","https://images.unsplash.com/photo-1771186936875-f80e00ec1127?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=600&q=80",[97,98],{"platform":57,"url":15},{"platform":14,"url":15},"src/content/docs/2026-04-17-relay-tower.md","f3ef5da7d86309eb",{"html":19,"metadata":102},{"headings":103,"localImagePaths":104,"remoteImagePaths":105,"frontmatter":106,"imagePaths":110},[],[],[],{"title":90,"date":91,"category":92,"description":93,"readTime":94,"coverImage":95,"videoLinks":107},[108,109],{"platform":57,"url":15},{"platform":14,"url":15},[],"2026-04-20-sheep-vlog",{"id":111,"data":113,"filePath":121,"digest":122,"rendered":123},{"title":114,"date":115,"category":51,"description":116,"readTime":117,"coverImage":118,"videoLinks":119},"海拔4500米的清晨：羊羊们的交谈线甘","2026.04.20","循着青藏高原深处的曲折路段，我来到了这里——四千五百米海拔上如画一般的高山牧场。一个安宁早晨，羊群缓缓移动在雪山映衬下呈现极致纯净。","10 min","https://images.unsplash.com/photo-1760410719961-0bb9710ada19?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=600&q=80",[120],{"platform":57,"url":15},"src/content/docs/2026-04-20-sheep-vlog.md","40e679273f5816a0",{"html":19,"metadata":124},{"headings":125,"localImagePaths":126,"remoteImagePaths":127,"frontmatter":128,"imagePaths":131},[],[],[],{"title":114,"date":115,"category":51,"description":116,"readTime":117,"coverImage":118,"videoLinks":129},[130],{"platform":57,"url":15},[],"equipment",["Map",134,135,153,154,171,172],"ai-compute",{"id":134,"data":136,"filePath":152},{"id":134,"icon":137,"title":138,"items":139},"Cpu","AI & 计算系统",[140,143,146,149],{"name":141,"spec":142},"AI 推理服务器","4×NVIDIA L40 · 80GB VRAM",{"name":144,"spec":145},"边缘工作站","NVIDIA Jetson Orin · 64GB",{"name":147,"spec":148},"卫星通信","Starlink Gen 3 · 低轨卫星",{"name":150,"spec":151},"散热系统","液冷循环 · 45°C 环境运行","src/data/equipment.json","digital-fab",{"id":153,"data":155,"filePath":152},{"id":153,"icon":156,"title":157,"items":158},"Factory","数字加工中心",[159,162,165,168],{"name":160,"spec":161},"3D 打印机","Bambu Lab X1C · 多色打印",{"name":163,"spec":164},"激光切割机","xTool D1 Pro · 20W 模组",{"name":166,"spec":167},"数控铣床","CNC 3018 Pro · 铝材加工",{"name":169,"spec":170},"电子工作台","示波器 · 焊台 · 万用表","power-life",{"id":171,"data":173,"filePath":152},{"id":171,"icon":174,"title":175,"items":176},"BatteryCharging","能源与生活",[177,180,183,186],{"name":178,"spec":179},"太阳能板","2×800W 可折叠 · JA Solar",{"name":181,"spec":182},"储能电池","LiFePO₄ 2000Ah · 磷酸铁锂",{"name":184,"spec":185},"逆变器","5kW 纯正弦波 · 离网/并网",{"name":187,"spec":188},"净水系统","RO反渗透 · 200L水箱","faq",["Map",191,192,203,204,217,218],"basics",{"id":191,"data":193,"filePath":202},{"id":191,"label":194,"items":195},"基本概念",[196,199],{"question":197,"answer":198},"什么是「在地」？","满足两个条件：① 你所在区域与基地车路线覆盖的省市县乡重合；② 你能完成项目的组织和落地。",{"question":200,"answer":201},"团队如何构成？","车上固定 3-4 人（领队、技术、媒体）。领队由柴火内部担任，其余通过招募开放。","src/data/faq.json","costs",{"id":203,"data":205,"filePath":202},{"id":203,"label":206,"items":207},"费用与回报",[208,211,214],{"question":209,"answer":210},"费用怎么算？","不提供薪资。参与期间的路上交通、食宿由项目承担，并购买人身保险。到达路段起点的交通费需自理。",{"question":212,"answer":213},"个人能收获什么？","成为中国首台科技共创移动实验室的核心成员；亲历 AI、开源硬件与农业、环保、教育等领域的深度碰撞；结识科技、公益、学术、媒体等多元领域的同行者。",{"question":215,"answer":216},"机构/企业能收获什么？","品牌共创与百万级曝光；与在地需求结合的技术验证与场景落地机会；深度参与 SDG 相关项目，践行科技向善。","process",{"id":217,"data":219,"filePath":202},{"id":217,"label":220,"items":221},"申请流程",[222,225],{"question":223,"answer":224},"招募何时截止？","持续招募，滚动录取，招满即止。建议尽早报名。",{"question":226,"answer":227},"申请到录取要多久？","提交后 7 个工作日内回复 → 线上面试 → 通过后参加线上行前培训（项目背景、安全须知、共创原则）。","heroes",["Map",230,231,236,237,241,242,246,247],"canyon-road",{"id":230,"data":232,"filePath":235},{"id":230,"image":233,"alt":234},"https://images.unsplash.com/photo-1494783367193-149034c05e8f?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","山间蜿蜒公路与峡谷","src/data/heroes.json","desert-road",{"id":236,"data":238,"filePath":235},{"id":236,"image":239,"alt":240},"https://images.unsplash.com/photo-1540390769625-2fc3f8b1d50c?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","沙漠戈壁越野公路","plateau-lake",{"id":241,"data":243,"filePath":235},{"id":241,"image":244,"alt":245},"https://images.unsplash.com/photo-1501785888041-af3ef285b470?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","高原湖泊与远山","snow-mountain",{"id":246,"data":248,"filePath":235},{"id":246,"image":249,"alt":250},"https://images.unsplash.com/photo-1506905925346-21bda4d32df4?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","中国西部雪山与草原壮阔风光","meta::meta",["Map",253,254,255,256,257,258],"astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"server\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":false,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":false,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image\",\"entrypoint\":\"@astrojs/cloudflare/image-transform-endpoint\"},\"service\":{\"entrypoint\":\"@astrojs/cloudflare/image-service-workerd\",\"config\":{}},\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"csp\":false,\"actionBodySizeLimit\":1048576,\"serverIslandBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"prerenderConflictBehavior\":\"warn\",\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"chromeDevtoolsWorkspace\":false,\"svgo\":false,\"rustCompiler\":false,\"queuedRendering\":{\"enabled\":false}},\"legacy\":{\"collectionsBackwardsCompat\":false},\"session\":{\"driver\":{\"entrypoint\":\"unstorage/drivers/cloudflare-kv-binding\",\"config\":{\"binding\":\"SESSION\"}}}}","astro-version","6.0.8","content-config-digest","4a25cc2bb55e3c04","notes",["Map",261,262,281,282,301,302],"2025-02-14-solar",{"id":261,"data":263,"filePath":271,"digest":272,"rendered":273},{"title":264,"date":265,"description":266,"image":267,"tags":268},"续航方案：太阳能板的挑战","2025/02/14","经过反复测试与验证，我们在基地车顶部加装了两组可折叠太阳能板组，每组峰值功率达800W。配合车载2000Ah锂电池组与智能电池管理系统，能在荒野停留时持续为AI服务器和数字加工设备提供动力。","https://images.unsplash.com/photo-1509391366360-2e959784a276?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[269,270],"能源","太阳能","src/content/notes/2025-02-14-solar.md","2ff082a8e518743f",{"html":19,"metadata":274},{"headings":275,"localImagePaths":276,"remoteImagePaths":277,"frontmatter":278,"imagePaths":280},[],[],[],{"title":264,"date":265,"description":266,"image":267,"tags":279},[269,270],[],"2025-03-01-3d-scan",{"id":281,"data":283,"filePath":291,"digest":292,"rendered":293},{"title":284,"date":285,"description":286,"image":287,"tags":288},"基地车低分辨率扫描实践","2025/03/01","要展开设计，首先想到的是如何获得车辆的数字化模型。作为改装小白，我想在动手之前，先去熟悉的 SketchUp 里看看有哪些前辈的设计方案可供参考。","https://images.unsplash.com/photo-1581094794329-c8112a89af12?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[289,290],"3D扫描","数字化","src/content/notes/2025-03-01-3d-scan.md","7643cf558f9aeda8",{"html":19,"metadata":294},{"headings":295,"localImagePaths":296,"remoteImagePaths":297,"frontmatter":298,"imagePaths":300},[],[],[],{"title":284,"date":285,"description":286,"image":287,"tags":299},[289,290],[],"2025-03-12-research",{"id":301,"data":303,"filePath":311,"digest":312,"rendered":313},{"title":304,"date":305,"description":306,"image":307,"tags":308},"移动创客空间与 DIY 露营车研究","2025/03/12-25","改装一辆移动创客空间，既不同于普通的房车露营改装，也不同于固定的创客空间搭建。我们需要在有限空间里兼顾工作坊、展示、教学、旅居等多重功能。","https://images.unsplash.com/photo-1504222490345-c075b6008014?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[309,310],"调研","设计","src/content/notes/2025-03-12-research.md","d015d787c2fd568e",{"html":19,"metadata":314},{"headings":315,"localImagePaths":316,"remoteImagePaths":317,"frontmatter":318,"imagePaths":320},[],[],[],{"title":304,"date":305,"description":306,"image":307,"tags":319},[309,310],[],"partners",["Map",323,324,328,329,332,333,336,337,340,341,344,345],"dji",{"id":323,"data":325,"filePath":327},{"id":323,"name":326},"DJI","src/data/partners.json","maker-media",{"id":328,"data":330,"filePath":327},{"id":328,"name":331},"Maker Media","nvidia",{"id":332,"data":334,"filePath":327},{"id":332,"name":335},"NVIDIA","seeed",{"id":336,"data":338,"filePath":327},{"id":336,"name":339},"Seeed Studio","starlink",{"id":340,"data":342,"filePath":327},{"id":340,"name":343},"Starlink","unesco",{"id":344,"data":346,"filePath":327},{"id":3