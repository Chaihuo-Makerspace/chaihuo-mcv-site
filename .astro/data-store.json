[["Map",1,2,106,107,163,164,202,203,225,226,233,234,296,297,315,316],"docs",["Map",3,4,37,38,72,73],"day15-chongqing-hotpot",{"id":3,"data":5,"body":18,"filePath":19,"digest":20,"rendered":21},{"title":6,"date":7,"category":8,"description":9,"author":10,"readTime":11,"coverImage":12,"videoLinks":13,"tags":14},"改装日记：边缘算力舱的诞生","2026.03.10","路上VLOG","4块NVIDIA L40 GPU装进一台VAN——从机柜设计到散热方案，记录边缘算力舱从图纸到实物的全过程。","志鹏","5 分钟","https://images.unsplash.com/photo-1558494949-ef010cbdcc31?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[],[15,16,17],"改装","算力","GPU","## 散热是最大挑战\n\n车内密闭空间加上深圳三月的气温，GPU满载15分钟温度就逼近阈值。\n\n最终方案：独立进风通道 + 车顶排风扇，形成定向气流，不和乘员舱混用空气。\n\n## 测试结果\n\n完全断网、纯车载供电条件下：\n- Llama 3 70B 量化版：离线问答响应 \u003C 2秒\n- Whisper 实时翻译：普通话→英语，延迟约1.5秒\n- SD XL 图像生成：单张约8秒\n\n## 下一步\n\n等电气系统联调完成后，还要做一轮高温和低温极端环境测试。","src/content/docs/day15-chongqing-hotpot.md","e4e470ac4c20a590",{"html":22,"metadata":23},"\u003Ch2 id=\"散热是最大挑战\">散热是最大挑战\u003C/h2>\n\u003Cp>车内密闭空间加上深圳三月的气温，GPU满载15分钟温度就逼近阈值。\u003C/p>\n\u003Cp>最终方案：独立进风通道 + 车顶排风扇，形成定向气流，不和乘员舱混用空气。\u003C/p>\n\u003Ch2 id=\"测试结果\">测试结果\u003C/h2>\n\u003Cp>完全断网、纯车载供电条件下：\u003C/p>\n\u003Cul>\n\u003Cli>Llama 3 70B 量化版：离线问答响应 &#x3C; 2秒\u003C/li>\n\u003Cli>Whisper 实时翻译：普通话→英语，延迟约1.5秒\u003C/li>\n\u003Cli>SD XL 图像生成：单张约8秒\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"下一步\">下一步\u003C/h2>\n\u003Cp>等电气系统联调完成后，还要做一轮高温和低温极端环境测试。\u003C/p>",{"headings":24,"localImagePaths":32,"remoteImagePaths":33,"frontmatter":34,"imagePaths":36},[25,28,30],{"depth":26,"slug":27,"text":27},2,"散热是最大挑战",{"depth":26,"slug":29,"text":29},"测试结果",{"depth":26,"slug":31,"text":31},"下一步",[],[],{"title":6,"date":7,"category":8,"description":9,"author":10,"coverImage":12,"readTime":11,"tags":35},[15,16,17],[],"relay-tower-documentary",{"id":37,"data":39,"body":52,"filePath":53,"digest":54,"rendered":55},{"title":40,"date":41,"category":42,"description":43,"author":44,"readTime":45,"coverImage":46,"videoLinks":47,"tags":48},"21省23城路线背后的故事","2026.01.20","公益合作纪录片","从深圳出发，横跨21省23城，行驶约19000公里后返回深圳。为什么是这条路？每一站选择背后的地理、社区与技术考量。","冯磊","7 分钟","https://images.unsplash.com/photo-1524661135-423995f22d0b?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[],[49,50,51],"路线","规划","城市","## 路线概览\n\n深圳→合浦→肇兴→酉阳→雅安→康定→林芝→喀什→敦煌→中卫→榆林→鄂尔多斯→大庆→济宁→沧州→太原→淮南→扬州→崇明→杭州→襄阳→凤凰→广州→深圳\n\n横跨 21 个省级行政区，途经 23 座城市，预计行驶约 19000 公里，历时 200 天。\n\n## 三个选择维度\n\n1. **地理多样性**：跨越三大地形阶梯，覆盖六种气候类型\n2. **社区连接**：每站至少有一个合作社区或学校可以落地活动\n3. **充电可达**：纯电车型，必须确保站与站之间有可靠充电设施\n\n## 最难的一段\n\n雅安到林芝。海拔从 600m 爬升到 3000m+，电池性能在低温高海拔下会打折扣，目前正在和吉利工程团队沟通高原适配方案。\n\n## 马年路线\n\n2026 是马年。我们的路线在地图上画出来，恰好形似一匹奔马——这不是刻意设计，但发现之后，大家觉得这是个好兆头。","src/content/docs/relay-tower-documentary.md","75aa0af56501b592",{"html":56,"metadata":57},"\u003Ch2 id=\"路线概览\">路线概览\u003C/h2>\n\u003Cp>深圳→合浦→肇兴→酉阳→雅安→康定→林芝→喀什→敦煌→中卫→榆林→鄂尔多斯→大庆→济宁→沧州→太原→淮南→扬州→崇明→杭州→襄阳→凤凰→广州→深圳\u003C/p>\n\u003Cp>横跨 21 个省级行政区，途经 23 座城市，预计行驶约 19000 公里，历时 200 天。\u003C/p>\n\u003Ch2 id=\"三个选择维度\">三个选择维度\u003C/h2>\n\u003Col>\n\u003Cli>\u003Cstrong>地理多样性\u003C/strong>：跨越三大地形阶梯，覆盖六种气候类型\u003C/li>\n\u003Cli>\u003Cstrong>社区连接\u003C/strong>：每站至少有一个合作社区或学校可以落地活动\u003C/li>\n\u003Cli>\u003Cstrong>充电可达\u003C/strong>：纯电车型，必须确保站与站之间有可靠充电设施\u003C/li>\n\u003C/ol>\n\u003Ch2 id=\"最难的一段\">最难的一段\u003C/h2>\n\u003Cp>雅安到林芝。海拔从 600m 爬升到 3000m+，电池性能在低温高海拔下会打折扣，目前正在和吉利工程团队沟通高原适配方案。\u003C/p>\n\u003Ch2 id=\"马年路线\">马年路线\u003C/h2>\n\u003Cp>2026 是马年。我们的路线在地图上画出来，恰好形似一匹奔马——这不是刻意设计，但发现之后，大家觉得这是个好兆头。\u003C/p>",{"headings":58,"localImagePaths":67,"remoteImagePaths":68,"frontmatter":69,"imagePaths":71},[59,61,63,65],{"depth":26,"slug":60,"text":60},"路线概览",{"depth":26,"slug":62,"text":62},"三个选择维度",{"depth":26,"slug":64,"text":64},"最难的一段",{"depth":26,"slug":66,"text":66},"马年路线",[],[],{"title":40,"date":41,"category":42,"description":43,"author":44,"coverImage":46,"readTime":45,"tags":70},[49,50,51],[],"village-teacher-interview",{"id":72,"data":74,"body":87,"filePath":88,"digest":89,"rendered":90},{"title":75,"date":76,"category":77,"description":78,"author":79,"readTime":80,"coverImage":81,"videoLinks":82,"tags":83},"冯磊：为什么要把一台VAN改成移动实验室？","2026.02.15","人物访谈","基地车领队冯磊讲述项目缘起——从柴火创客空间15年的积累，到决定把技术搬上一台车开往中国最需要它的地方。","柴火纪实组","8 分钟","https://images.unsplash.com/photo-1581092160562-40aa08e78837?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[],[84,85,86],"团队","愿景","访谈","## 为什么是一台车？\n\n\"创客空间在深圳做了十五年，来的人都是主动找过来的。但真正需要这些技术的人，往往走不出大山。\"\n\n冯磊靠在改装中的基地车旁，擦了擦手上的机油。\n\n## 从想法到立项\n\n2025年6月，团队正式提出基地车方案。三个月选车、半年改装，目标是打造一台能在离线环境下独立运行的移动AI实验室。\n\n## 最大的挑战\n\n> \"不是技术问题，是空间问题。怎么在5.5米的车厢里塞下4块GPU、一台3D打印机、还有人住的地方——这比写代码难多了。\"","src/content/docs/village-teacher-interview.md","81b770084d15abdc",{"html":91,"metadata":92},"\u003Ch2 id=\"为什么是一台车\">为什么是一台车？\u003C/h2>\n\u003Cp>“创客空间在深圳做了十五年，来的人都是主动找过来的。但真正需要这些技术的人，往往走不出大山。”\u003C/p>\n\u003Cp>冯磊靠在改装中的基地车旁，擦了擦手上的机油。\u003C/p>\n\u003Ch2 id=\"从想法到立项\">从想法到立项\u003C/h2>\n\u003Cp>2025年6月，团队正式提出基地车方案。三个月选车、半年改装，目标是打造一台能在离线环境下独立运行的移动AI实验室。\u003C/p>\n\u003Ch2 id=\"最大的挑战\">最大的挑战\u003C/h2>\n\u003Cblockquote>\n\u003Cp>“不是技术问题，是空间问题。怎么在5.5米的车厢里塞下4块GPU、一台3D打印机、还有人住的地方——这比写代码难多了。”\u003C/p>\n\u003C/blockquote>",{"headings":93,"localImagePaths":101,"remoteImagePaths":102,"frontmatter":103,"imagePaths":105},[94,97,99],{"depth":26,"slug":95,"text":96},"为什么是一台车","为什么是一台车？",{"depth":26,"slug":98,"text":98},"从想法到立项",{"depth":26,"slug":100,"text":100},"最大的挑战",[],[],{"title":75,"date":76,"category":77,"description":78,"author":79,"coverImage":81,"readTime":80,"tags":104},[84,85,86],[],"equipment",["Map",108,109,127,128,145,146],"ai-compute",{"id":108,"data":110,"filePath":126},{"id":108,"icon":111,"title":112,"items":113},"Cpu","AI & 计算系统",[114,117,120,123],{"name":115,"spec":116},"AI 推理服务器","4×NVIDIA L40 · 80GB VRAM",{"name":118,"spec":119},"边缘工作站","NVIDIA Jetson Orin · 64GB",{"name":121,"spec":122},"卫星通信","Starlink Gen 3 · 低轨卫星",{"name":124,"spec":125},"散热系统","液冷循环 · 45°C 环境运行","src/data/equipment.json","digital-fab",{"id":127,"data":129,"filePath":126},{"id":127,"icon":130,"title":131,"items":132},"Factory","数字加工中心",[133,136,139,142],{"name":134,"spec":135},"3D 打印机","Bambu Lab X1C · 多色打印",{"name":137,"spec":138},"激光切割机","xTool D1 Pro · 20W 模组",{"name":140,"spec":141},"数控铣床","CNC 3018 Pro · 铝材加工",{"name":143,"spec":144},"电子工作台","示波器 · 焊台 · 万用表","power-life",{"id":145,"data":147,"filePath":126},{"id":145,"icon":148,"title":149,"items":150},"BatteryCharging","能源与生活",[151,154,157,160],{"name":152,"spec":153},"太阳能板","2×800W 可折叠 · JA Solar",{"name":155,"spec":156},"储能电池","LiFePO₄ 2000Ah · 磷酸铁锂",{"name":158,"spec":159},"逆变器","5kW 纯正弦波 · 离网/并网",{"name":161,"spec":162},"净水系统","RO反渗透 · 200L水箱","faq",["Map",165,166,177,178,191,192],"basics",{"id":165,"data":167,"filePath":176},{"id":165,"label":168,"items":169},"基本概念",[170,173],{"question":171,"answer":172},"什么是「在地」？","满足两个条件：① 你所在区域与基地车路线覆盖的省市县乡重合；② 你能完成项目的组织和落地。",{"question":174,"answer":175},"团队如何构成？","车上固定 3-4 人（领队、技术、媒体）。领队由柴火内部担任，其余通过招募开放。","src/data/faq.json","costs",{"id":177,"data":179,"filePath":176},{"id":177,"label":180,"items":181},"费用与回报",[182,185,188],{"question":183,"answer":184},"费用怎么算？","不提供薪资。参与期间的路上交通、食宿由项目承担，并购买人身保险。到达路段起点的交通费需自理。",{"question":186,"answer":187},"个人能收获什么？","成为中国首台科技共创移动实验室的核心成员；亲历 AI、开源硬件与农业、环保、教育等领域的深度碰撞；结识科技、公益、学术、媒体等多元领域的同行者。",{"question":189,"answer":190},"机构/企业能收获什么？","品牌共创与百万级曝光；与在地需求结合的技术验证与场景落地机会；深度参与 SDG 相关项目，践行科技向善。","process",{"id":191,"data":193,"filePath":176},{"id":191,"label":194,"items":195},"申请流程",[196,199],{"question":197,"answer":198},"招募何时截止？","持续招募，滚动录取，招满即止。建议尽早报名。",{"question":200,"answer":201},"申请到录取要多久？","提交后 7 个工作日内回复 → 线上面试 → 通过后参加线上行前培训（项目背景、安全须知、共创原则）。","heroes",["Map",204,205,210,211,215,216,220,221],"mountain-road",{"id":204,"data":206,"filePath":209},{"id":204,"image":207,"alt":208},"https://images.unsplash.com/photo-1545569341-9eb8b30979d9?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","山间公路旅途 — TODO: 替换为真实旅途照片","src/data/heroes.json","rural-china",{"id":210,"data":212,"filePath":209},{"id":210,"image":213,"alt":214},"https://images.unsplash.com/photo-1537531383496-18cf04e86238?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","中国乡村风光 — TODO: 替换为基地车途经乡村实拍","van-on-road",{"id":215,"data":217,"filePath":209},{"id":215,"image":218,"alt":219},"https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","基地车穿越中国公路 — TODO: 替换为真实车辆照片","workshop-van",{"id":220,"data":222,"filePath":209},{"id":220,"image":223,"alt":224},"https://images.unsplash.com/photo-1504384308090-c894fdcc538d?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","移动实验室内部 — TODO: 替换为车内实拍","meta::meta",["Map",227,228,229,230,231,232],"astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"site\":\"https://mcv.chaihuo.org\",\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"server\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":false,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":false,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image\",\"entrypoint\":\"astro/assets/endpoint/dev\"},\"service\":{\"entrypoint\":\"astro/assets/services/sharp\",\"config\":{}},\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"csp\":false,\"actionBodySizeLimit\":1048576,\"serverIslandBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"prerenderConflictBehavior\":\"warn\",\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"chromeDevtoolsWorkspace\":false,\"svgo\":false,\"rustCompiler\":false,\"queuedRendering\":{\"enabled\":false}},\"legacy\":{\"collectionsBackwardsCompat\":false},\"session\":{\"driver\":{\"entrypoint\":\"unstorage/drivers/fs-lite\",\"config\":{\"base\":\"/Users/spencer/Seeed/dev/web-design/xia-chaihuo-vancar/node_modules/.astro/sessions\"}}}}","astro-version","6.0.8","content-config-digest","03c81a113da33420","notes",["Map",235,236,256,257,276,277],"2025-02-14-solar",{"id":235,"data":237,"filePath":245,"digest":246,"rendered":247},{"title":238,"date":239,"description":240,"image":241,"tags":242},"续航方案：太阳能板的挑战","2025/02/14","经过反复测试与验证，我们在基地车顶部加装了两组可折叠太阳能板组，每组峰值功率达800W。配合车载2000Ah锂电池组与智能电池管理系统，能在荒野停留时持续为AI服务器和数字加工设备提供动力。","https://images.unsplash.com/photo-1509391366360-2e959784a276?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[243,244],"能源","太阳能","src/content/notes/2025-02-14-solar.md","2ff082a8e518743f",{"html":248,"metadata":249},"",{"headings":250,"localImagePaths":251,"remoteImagePaths":252,"frontmatter":253,"imagePaths":255},[],[],[],{"title":238,"date":239,"description":240,"image":241,"tags":254},[243,244],[],"2025-03-01-3d-scan",{"id":256,"data":258,"filePath":266,"digest":267,"rendered":268},{"title":259,"date":260,"description":261,"image":262,"tags":263},"基地车低分辨率扫描实践","2025/03/01","要展开设计，首先想到的是如何获得车辆的数字化模型。作为改装小白，我想在动手之前，先去熟悉的 SketchUp 里看看有哪些前辈的设计方案可供参考。","https://images.unsplash.com/photo-1581094794329-c8112a89af12?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[264,265],"3D扫描","数字化","src/content/notes/2025-03-01-3d-scan.md","7643cf558f9aeda8",{"html":248,"metadata":269},{"headings":270,"localImagePaths":271,"remoteImagePaths":272,"frontmatter":273,"imagePaths":275},[],[],[],{"title":259,"date":260,"description":261,"image":262,"tags":274},[264,265],[],"2025-03-12-research",{"id":276,"data":278,"filePath":286,"digest":287,"rendered":288},{"title":279,"date":280,"description":281,"image":282,"tags":283},"移动创客空间与 DIY 露营车研究","2025/03/12-25","改装一辆移动创客空间，既不同于普通的房车露营改装，也