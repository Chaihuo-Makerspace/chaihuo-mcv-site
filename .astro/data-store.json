[["Map",1,2,105,106,162,163,201,202,224,225,232,233,295,296,322,323],"docs",["Map",3,4,37,38,73,74],"day15-chongqing-hotpot",{"id":3,"data":5,"body":18,"filePath":19,"digest":20,"rendered":21},{"title":6,"date":7,"category":8,"description":9,"author":10,"readTime":11,"coverImage":12,"videoLinks":13,"tags":14},"Day 15：在重庆吃了一顿改变人生的火锅","2026.04.20","路上VLOG","从贵阳翻山越岭到重庆，基地车在连续 8 小时的山路后终于抵达。晚上和当地创客社区的朋友们围坐在火锅旁，聊技术、聊未来、聊那些路上遇到的意外。","小夏","5 分钟","https://images.unsplash.com/photo-1551218808-94e220e084d2?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[],[15,16,17],"重庆","创客社区","日常","## 山路十八弯\n\n从贵阳出发，导航显示 380 公里，预计 5 小时。实际花了 8 小时。\n\n基地车的太阳能板在隧道群里完全没用，好在电池储备充足。但连续的急弯让车载设备的固定支架经受了严峻考验——我们不得不在途中停下来重新加固 3D 打印机的底座。\n\n## 重庆创客夜\n\n到达重庆已是傍晚。当地的创客社区早已在一家老火锅店等候。\n\n红油翻滚中，我们聊了很多：\n\n- 边缘计算在弱网环境的实际表现\n- 太阳能系统在阴雨天气的应对策略\n- 下一站成都的计划\n\n## 一句话总结\n\n路上最好的技术交流，往往发生在火锅桌旁。","src/content/docs/day15-chongqing-hotpot.md","9e99ee072c43c370",{"html":22,"metadata":23},"\u003Ch2 id=\"山路十八弯\">山路十八弯\u003C/h2>\n\u003Cp>从贵阳出发，导航显示 380 公里，预计 5 小时。实际花了 8 小时。\u003C/p>\n\u003Cp>基地车的太阳能板在隧道群里完全没用，好在电池储备充足。但连续的急弯让车载设备的固定支架经受了严峻考验——我们不得不在途中停下来重新加固 3D 打印机的底座。\u003C/p>\n\u003Ch2 id=\"重庆创客夜\">重庆创客夜\u003C/h2>\n\u003Cp>到达重庆已是傍晚。当地的创客社区早已在一家老火锅店等候。\u003C/p>\n\u003Cp>红油翻滚中，我们聊了很多：\u003C/p>\n\u003Cul>\n\u003Cli>边缘计算在弱网环境的实际表现\u003C/li>\n\u003Cli>太阳能系统在阴雨天气的应对策略\u003C/li>\n\u003Cli>下一站成都的计划\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"一句话总结\">一句话总结\u003C/h2>\n\u003Cp>路上最好的技术交流，往往发生在火锅桌旁。\u003C/p>",{"headings":24,"localImagePaths":32,"remoteImagePaths":33,"frontmatter":34,"imagePaths":36},[25,28,30],{"depth":26,"slug":27,"text":27},2,"山路十八弯",{"depth":26,"slug":29,"text":29},"重庆创客夜",{"depth":26,"slug":31,"text":31},"一句话总结",[],[],{"title":6,"date":7,"category":8,"description":9,"author":10,"coverImage":12,"readTime":11,"tags":35},[15,16,17],[],"relay-tower-documentary",{"id":37,"data":39,"body":53,"filePath":54,"digest":55,"rendered":56},{"title":40,"date":41,"category":42,"description":43,"author":44,"readTime":45,"coverImage":46,"videoLinks":47,"tags":48},"荒野信号：戈壁滩上的基站中继塔","2026.04.17","公益合作纪录片","在甘肃敦煌以西的戈壁滩，我们与中国移动公益团队合作，利用基地车的边缘算力搭建了一座临时基站中继塔，为方圆 30 公里内的牧民家庭提供网络接入。","柴火纪实组","15 分钟","https://images.unsplash.com/photo-1509316785289-025f5b846b35?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[],[49,50,51,52],"基站","公益","甘肃","合作","## 项目背景\n\n敦煌以西 200 公里的戈壁滩上，散居着数十户牧民家庭。最近的基站在 50 公里外，手机信号几乎为零。\n\n中国移动的公益团队联系到我们，希望利用基地车的移动算力和太阳能供电系统，搭建一座临时中继塔。\n\n## 技术方案\n\n- **供电**：基地车的 5kW 太阳能系统 + 20kWh 储能电池\n- **算力**：车载边缘服务器运行信号转发和数据缓存\n- **天线**：可折叠桅杆，展开高度 12 米\n\n## 搭建过程\n\n凌晨 4 点开工。沙尘暴随时可能来袭，我们必须在天亮前完成主体结构。\n\n## 成果\n\n基站运行 72 小时，覆盖半径 30 公里：\n\n- 47 户牧民家庭首次接入移动网络\n- 12 名儿童通过网络完成了远程作业提交\n- 3 位老人与在城市工作的子女进行了视频通话\n\n> \"能看到孙子的脸，比什么都好。\" —— 牧民阿依古丽","src/content/docs/relay-tower-documentary.md","c67dffe16da37071",{"html":57,"metadata":58},"\u003Ch2 id=\"项目背景\">项目背景\u003C/h2>\n\u003Cp>敦煌以西 200 公里的戈壁滩上，散居着数十户牧民家庭。最近的基站在 50 公里外，手机信号几乎为零。\u003C/p>\n\u003Cp>中国移动的公益团队联系到我们，希望利用基地车的移动算力和太阳能供电系统，搭建一座临时中继塔。\u003C/p>\n\u003Ch2 id=\"技术方案\">技术方案\u003C/h2>\n\u003Cul>\n\u003Cli>\u003Cstrong>供电\u003C/strong>：基地车的 5kW 太阳能系统 + 20kWh 储能电池\u003C/li>\n\u003Cli>\u003Cstrong>算力\u003C/strong>：车载边缘服务器运行信号转发和数据缓存\u003C/li>\n\u003Cli>\u003Cstrong>天线\u003C/strong>：可折叠桅杆，展开高度 12 米\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"搭建过程\">搭建过程\u003C/h2>\n\u003Cp>凌晨 4 点开工。沙尘暴随时可能来袭，我们必须在天亮前完成主体结构。\u003C/p>\n\u003Ch2 id=\"成果\">成果\u003C/h2>\n\u003Cp>基站运行 72 小时，覆盖半径 30 公里：\u003C/p>\n\u003Cul>\n\u003Cli>47 户牧民家庭首次接入移动网络\u003C/li>\n\u003Cli>12 名儿童通过网络完成了远程作业提交\u003C/li>\n\u003Cli>3 位老人与在城市工作的子女进行了视频通话\u003C/li>\n\u003C/ul>\n\u003Cblockquote>\n\u003Cp>“能看到孙子的脸，比什么都好。” —— 牧民阿依古丽\u003C/p>\n\u003C/blockquote>",{"headings":59,"localImagePaths":68,"remoteImagePaths":69,"frontmatter":70,"imagePaths":72},[60,62,64,66],{"depth":26,"slug":61,"text":61},"项目背景",{"depth":26,"slug":63,"text":63},"技术方案",{"depth":26,"slug":65,"text":65},"搭建过程",{"depth":26,"slug":67,"text":67},"成果",[],[],{"title":40,"date":41,"category":42,"description":43,"author":44,"coverImage":46,"readTime":45,"tags":71},[49,50,51,52],[],"village-teacher-interview",{"id":73,"data":75,"body":87,"filePath":88,"digest":89,"rendered":90},{"title":76,"date":77,"category":78,"description":79,"author":44,"readTime":80,"coverImage":81,"videoLinks":82,"tags":83},"乡村教师王老师：AI 让孩子们看到了更大的世界","2026.04.12","人物访谈","在贵州黔东南的一所乡村小学，王老师和我们分享了基地车带来的 AI 教学工具如何改变了她的课堂。孩子们第一次用语音助手查阅资料，第一次通过 3D 打印把想象变成实物。","8 分钟","https://images.unsplash.com/photo-1509062522246-3755977927d7?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[],[84,85,86],"教育","贵州","AI教学","## 初见基地车\n\n四月的黔东南，山间雾气还未散去。我们的基地车沿着蜿蜒的山路驶入苗寨，停在了王老师所在的村小门口。\n\n\"我教了二十年书，从来没见过这样的车。\"王老师笑着说，眼里满是好奇。\n\n## 课堂里的变化\n\n基地车携带的边缘计算设备让离线 AI 助手成为可能。在没有稳定网络的山村，孩子们第一次体验了：\n\n- **语音问答**：用普通话和苗语向 AI 提问\n- **3D 打印**：把画在纸上的小动物变成立体模型\n- **编程入门**：通过图形化编程控制 LED 灯带\n\n## 王老师的话\n\n> \"技术不是冷冰冰的，它是有温度的。当我看到孩子们眼里的光，我知道这趟旅程是值得的。\"\n\n这是我们在路上听到的最动人的一句话。","src/content/docs/village-teacher-interview.md","0a7f3eb4ddbbc2aa",{"html":91,"metadata":92},"\u003Ch2 id=\"初见基地车\">初见基地车\u003C/h2>\n\u003Cp>四月的黔东南，山间雾气还未散去。我们的基地车沿着蜿蜒的山路驶入苗寨，停在了王老师所在的村小门口。\u003C/p>\n\u003Cp>“我教了二十年书，从来没见过这样的车。“王老师笑着说，眼里满是好奇。\u003C/p>\n\u003Ch2 id=\"课堂里的变化\">课堂里的变化\u003C/h2>\n\u003Cp>基地车携带的边缘计算设备让离线 AI 助手成为可能。在没有稳定网络的山村，孩子们第一次体验了：\u003C/p>\n\u003Cul>\n\u003Cli>\u003Cstrong>语音问答\u003C/strong>：用普通话和苗语向 AI 提问\u003C/li>\n\u003Cli>\u003Cstrong>3D 打印\u003C/strong>：把画在纸上的小动物变成立体模型\u003C/li>\n\u003Cli>\u003Cstrong>编程入门\u003C/strong>：通过图形化编程控制 LED 灯带\u003C/li>\n\u003C/ul>\n\u003Ch2 id=\"王老师的话\">王老师的话\u003C/h2>\n\u003Cblockquote>\n\u003Cp>“技术不是冷冰冰的，它是有温度的。当我看到孩子们眼里的光，我知道这趟旅程是值得的。”\u003C/p>\n\u003C/blockquote>\n\u003Cp>这是我们在路上听到的最动人的一句话。\u003C/p>",{"headings":93,"localImagePaths":100,"remoteImagePaths":101,"frontmatter":102,"imagePaths":104},[94,96,98],{"depth":26,"slug":95,"text":95},"初见基地车",{"depth":26,"slug":97,"text":97},"课堂里的变化",{"depth":26,"slug":99,"text":99},"王老师的话",[],[],{"title":76,"date":77,"category":78,"description":79,"author":44,"coverImage":81,"readTime":80,"tags":103},[84,85,86],[],"equipment",["Map",107,108,126,127,144,145],"ai-compute",{"id":107,"data":109,"filePath":125},{"id":107,"icon":110,"title":111,"items":112},"Cpu","AI & 计算系统",[113,116,119,122],{"name":114,"spec":115},"AI 推理服务器","4×NVIDIA L40 · 80GB VRAM",{"name":117,"spec":118},"边缘工作站","NVIDIA Jetson Orin · 64GB",{"name":120,"spec":121},"卫星通信","Starlink Gen 3 · 低轨卫星",{"name":123,"spec":124},"散热系统","液冷循环 · 45°C 环境运行","src/data/equipment.json","digital-fab",{"id":126,"data":128,"filePath":125},{"id":126,"icon":129,"title":130,"items":131},"Factory","数字加工中心",[132,135,138,141],{"name":133,"spec":134},"3D 打印机","Bambu Lab X1C · 多色打印",{"name":136,"spec":137},"激光切割机","xTool D1 Pro · 20W 模组",{"name":139,"spec":140},"数控铣床","CNC 3018 Pro · 铝材加工",{"name":142,"spec":143},"电子工作台","示波器 · 焊台 · 万用表","power-life",{"id":144,"data":146,"filePath":125},{"id":144,"icon":147,"title":148,"items":149},"BatteryCharging","能源与生活",[150,153,156,159],{"name":151,"spec":152},"太阳能板","2×800W 可折叠 · JA Solar",{"name":154,"spec":155},"储能电池","LiFePO₄ 2000Ah · 磷酸铁锂",{"name":157,"spec":158},"逆变器","5kW 纯正弦波 · 离网/并网",{"name":160,"spec":161},"净水系统","RO反渗透 · 200L水箱","faq",["Map",164,165,176,177,190,191],"basics",{"id":164,"data":166,"filePath":175},{"id":164,"label":167,"items":168},"基本概念",[169,172],{"question":170,"answer":171},"什么是「在地」？","满足两个条件：① 你所在区域与基地车路线覆盖的省市县乡重合；② 你能完成项目的组织和落地。",{"question":173,"answer":174},"团队如何构成？","车上固定 3-4 人（领队、技术、媒体）。领队由柴火内部担任，其余通过招募开放。","src/data/faq.json","costs",{"id":176,"data":178,"filePath":175},{"id":176,"label":179,"items":180},"费用与回报",[181,184,187],{"question":182,"answer":183},"费用怎么算？","不提供薪资。参与期间的路上交通、食宿由项目承担，并购买人身保险。到达路段起点的交通费需自理。",{"question":185,"answer":186},"个人能收获什么？","成为中国首台科技共创移动实验室的核心成员；亲历 AI、开源硬件与农业、环保、教育等领域的深度碰撞；结识科技、公益、学术、媒体等多元领域的同行者。",{"question":188,"answer":189},"机构/企业能收获什么？","品牌共创与百万级曝光；与在地需求结合的技术验证与场景落地机会；深度参与 SDG 相关项目，践行科技向善。","process",{"id":190,"data":192,"filePath":175},{"id":190,"label":193,"items":194},"申请流程",[195,198],{"question":196,"answer":197},"招募何时截止？","持续招募，滚动录取，招满即止。建议尽早报名。",{"question":199,"answer":200},"申请到录取要多久？","提交后 7 个工作日内回复 → 线上面试 → 通过后参加线上行前培训（项目背景、安全须知、共创原则）。","heroes",["Map",203,204,209,210,214,215,219,220],"canyon-road",{"id":203,"data":205,"filePath":208},{"id":203,"image":206,"alt":207},"https://images.unsplash.com/photo-1494783367193-149034c05e8f?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","山间蜿蜒公路与峡谷","src/data/heroes.json","desert-road",{"id":209,"data":211,"filePath":208},{"id":209,"image":212,"alt":213},"https://images.unsplash.com/photo-1540390769625-2fc3f8b1d50c?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","沙漠戈壁越野公路","plateau-lake",{"id":214,"data":216,"filePath":208},{"id":214,"image":217,"alt":218},"https://images.unsplash.com/photo-1501785888041-af3ef285b470?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","高原湖泊与远山","snow-mountain",{"id":219,"data":221,"filePath":208},{"id":219,"image":222,"alt":223},"https://images.unsplash.com/photo-1506905925346-21bda4d32df4?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=1920&q=80","中国西部雪山与草原壮阔风光","meta::meta",["Map",226,227,228,229,230,231],"astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"server\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":false,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":false,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image\",\"entrypoint\":\"@astrojs/cloudflare/image-transform-endpoint\"},\"service\":{\"entrypoint\":\"@astrojs/cloudflare/image-service-workerd\",\"config\":{}},\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"csp\":false,\"actionBodySizeLimit\":1048576,\"serverIslandBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"prerenderConflictBehavior\":\"warn\",\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"chromeDevtoolsWorkspace\":false,\"svgo\":false,\"rustCompiler\":false,\"queuedRendering\":{\"enabled\":false}},\"legacy\":{\"collectionsBackwardsCompat\":false},\"session\":{\"driver\":{\"entrypoint\":\"unstorage/drivers/cloudflare-kv-binding\",\"config\":{\"binding\":\"SESSION\"}}}}","astro-version","6.0.8","content-config-digest","259540ee99e7eede","notes",["Map",234,235,255,256,275,276],"2025-02-14-solar",{"id":234,"data":236,"filePath":244,"digest":245,"rendered":246},{"title":237,"date":238,"description":239,"image":240,"tags":241},"续航方案：太阳能板的挑战","2025/02/14","经过反复测试与验证，我们在基地车顶部加装了两组可折叠太阳能板组，每组峰值功率达800W。配合车载2000Ah锂电池组与智能电池管理系统，能在荒野停留时持续为AI服务器和数字加工设备提供动力。","https://images.unsplash.com/photo-1509391366360-2e959784a276?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[242,243],"能源","太阳能","src/content/notes/2025-02-14-solar.md","2ff082a8e518743f",{"html":247,"metadata":248},"",{"headings":249,"localImagePaths":250,"remoteImagePaths":251,"frontmatter":252,"imagePaths":254},[],[],[],{"title":237,"date":238,"description":239,"image":240,"tags":253},[242,243],[],"2025-03-01-3d-scan",{"id":255,"data":257,"filePath":265,"digest":266,"rendered":267},{"title":258,"date":259,"description":260,"image":261,"tags":262},"基地车低分辨率扫描实践","2025/03/01","要展开设计，首先想到的是如何获得车辆的数字化模型。作为改装小白，我想在动手之前，先去熟悉的 SketchUp 里看看有哪些前辈的设计方案可供参考。","https://images.unsplash.com/photo-1581094794329-c8112a89af12?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&w=800&q=80",[263,264],"3D扫描","数字化","src/co