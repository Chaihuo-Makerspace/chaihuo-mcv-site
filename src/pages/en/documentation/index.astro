---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import DocumentationContent from '@/app/components/DocumentationContent';
import { getCollection } from 'astro:content';
import type { Locale } from '@/i18n/index';
import docDict from '@/i18n/documentation';
import { categoryNames } from '@/i18n/documentation';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = docDict[locale];
const catNames = categoryNames[locale];

const docsCollection = await getCollection('docs');

const docs = docsCollection.map(doc => ({
  id: doc.id,
  slug: doc.id,
  date: doc.data.date,
  category: doc.data.category,
  categoryDisplay: catNames[doc.data.category] ?? doc.data.category,
  title: locale === 'en' && doc.data.title_en ? doc.data.title_en : doc.data.title,
  description: locale === 'en' && doc.data.description_en ? doc.data.description_en : doc.data.description,
  readTime: locale === 'en' && doc.data.readTime_en ? doc.data.readTime_en : doc.data.readTime,
  coverImage: doc.data.coverImage,
  videoLinks: doc.data.videoLinks,
  pdfName: doc.data.pdfName,
})).sort((a, b) => b.date.localeCompare(a.date));

const categories = [
  { key: '全部', label: t['filter.all'] },
  { key: '人物访谈', label: t['filter.interview'] },
  { key: '路上VLOG', label: t['filter.vlog'] },
  { key: '公益合作纪录片', label: t['filter.documentary'] },
];
---

<BaseLayout title={t['title']} description={t['description']}>
  <DocumentationContent client:load docs={docs} locale={locale} t={t} categories={categories} />
</BaseLayout>
