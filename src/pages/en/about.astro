---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import AboutContent from '@/app/components/AboutContent';
import timelineData from '@/data/timeline.json';
import partnersData from '@/data/partners.json';
import heroesData from '@/data/heroes.json';
import type { Locale } from '@/i18n/index';
import { localize } from '@/i18n/index';
import aboutDict from '@/i18n/about';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const t = aboutDict[locale];

const partners = partnersData.map(p => {
  const loc = localize(p, ['description'], locale);
  return { name: loc.name, description: loc.description };
});
---

<BaseLayout title={t['title']} description={t['description']}>
  <AboutContent
    client:load
    timelineData={timelineData.years}
    phases={timelineData.phases}
    partners={partners}
    heroImage={heroesData[0].image}
    locale={locale}
    t={t}
  />
</BaseLayout>
