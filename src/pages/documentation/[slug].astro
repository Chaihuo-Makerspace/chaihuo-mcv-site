---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);

const CATEGORY_COLORS: Record<string, string> = {
  '人物访谈': 'bg-blue-50 text-blue-700 border-blue-200',
  '路上VLOG': 'bg-amber-50 text-amber-700 border-amber-200',
  '公益合作纪录片': 'bg-purple-50 text-purple-700 border-purple-200',
};
---

<BaseLayout title={doc.data.title}>
  <article class="bg-surface min-h-screen">

    {/* 返回导航 */}
    <div class="max-w-3xl mx-auto px-6 pt-6">
      <a
        href="/documentation"
        class="inline-flex items-center gap-1.5 text-sm text-neutral-400 hover:text-neutral-900 transition-colors"
      >
        <span class="text-lg leading-none">&larr;</span>
        返回循迹中国
      </a>
    </div>

    {/* 文章头 */}
    <header class="max-w-3xl mx-auto px-6 pt-8 pb-6">
      <div class="flex items-center gap-3 mb-5 flex-wrap">
        <span class={`text-xs px-3 py-1 rounded-full font-medium border ${CATEGORY_COLORS[doc.data.category] ?? 'bg-neutral-50 text-neutral-700 border-neutral-200'}`}>
          {doc.data.category}
        </span>
        <span class="text-xs text-neutral-400">{doc.data.date}</span>
        {doc.data.readTime && (
          <span class="text-xs text-neutral-400">· {doc.data.readTime}</span>
        )}
      </div>

      <h1 class="text-2xl md:text-4xl font-bold text-neutral-900 leading-tight mb-4">
        {doc.data.title}
      </h1>

      <p class="text-neutral-500 text-base leading-relaxed">
        {doc.data.description}
      </p>

      {doc.data.author && (
        <p class="mt-4 text-sm text-neutral-400">文 / {doc.data.author}</p>
      )}
    </header>

    {/* 封面图 */}
    {doc.data.coverImage && (
      <div class="max-w-4xl mx-auto px-6 mb-10">
        <div class="rounded-lg overflow-hidden aspect-[2/1]">
          <img
            src={doc.data.coverImage}
            alt={doc.data.title}
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    )}

    {/* 正文 */}
    <div class="max-w-3xl mx-auto px-6 pb-16">
      <div class="prose prose-neutral max-w-none
        prose-headings:text-neutral-900 prose-headings:font-bold
        prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b prose-h2:border-neutral-200 prose-h2:pb-2
        prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-neutral-600 prose-p:leading-[1.8] prose-p:mb-5
        prose-blockquote:border-l-4 prose-blockquote:border-brand prose-blockquote:bg-brand-light prose-blockquote:rounded-r-lg prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:not-italic
        prose-blockquote:text-neutral-700
        prose-li:text-neutral-600 prose-li:leading-[1.8]
        prose-strong:text-neutral-900 prose-strong:font-semibold
        prose-a:text-brand-dark prose-a:underline prose-a:underline-offset-2
        prose-img:rounded-lg prose-img:shadow-sm
        prose-hr:border-neutral-200">
        <Content />
      </div>

      {/* 标签 */}
      {doc.data.tags.length > 0 && (
        <div class="mt-12 pt-6 border-t border-neutral-200 flex items-center gap-2 flex-wrap">
          {doc.data.tags.map((tag: string) => (
            <span class="text-xs px-3 py-1.5 bg-neutral-100 text-neutral-500 rounded-full hover:bg-neutral-200 transition-colors">
              #{tag}
            </span>
          ))}
        </div>
      )}

      {/* 底部返回 */}
      <div class="mt-10 pt-6 border-t border-neutral-200">
        <a
          href="/documentation"
          class="inline-flex items-center gap-1.5 text-sm text-neutral-400 hover:text-neutral-900 transition-colors"
        >
          <span class="text-lg leading-none">&larr;</span>
          返回循迹中国
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
