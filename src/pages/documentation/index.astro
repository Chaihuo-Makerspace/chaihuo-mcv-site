---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import DocumentationContent from '@/app/components/DocumentationContent';
import { getCollection } from 'astro:content';

const docsCollection = await getCollection('docs');

const docs = docsCollection.map(doc => ({
  id: doc.id,
  slug: doc.id,
  date: doc.data.date,
  category: doc.data.category,
  title: doc.data.title,
  description: doc.data.description,
  readTime: doc.data.readTime,
  coverImage: doc.data.coverImage,
  videoLinks: doc.data.videoLinks,
  pdfName: doc.data.pdfName,
})).sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout title="完整纪实" description="柴火基地车纪实——人物访谈、路上 Vlog、公益合作纪录片，记录每一个真实瞬间。">
  <DocumentationContent client:load docs={docs} />
</BaseLayout>
